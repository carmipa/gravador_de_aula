# Copie para .env e ajuste os valores.
# NUNCA commite o arquivo .env (credenciais).

# Pasta onde salvar as gravações (deixe vazio para usar a pasta do projeto)
GRAVACOES_DIR=

# Pasta do Google Drive para sincronizar (ex: C:\Users\SeuUsuario\Google Drive\Aulas)
# Se preenchida, o bot copia o arquivo para lá após gravar (Google Drive Desktop)
GDRIVE_PASTA_LOCAL=

# Opcional: ID da pasta no Google Drive para upload via API (ex: 1abc...xyz)
# GDRIVE_PASTA_ID=

# Código de vídeo: av1 | hevc_nvenc | hevc | h264
# av1 = menor arquivo, ótima qualidade (exige FFmpeg com libsvtav1)
# hevc_nvenc = HEVC na GPU NVIDIA (rápido, arquivos pequenos)
# hevc = HEVC em software (libx265)
# h264 = mais compatível, arquivos maiores
CODEC=av1

# Qualidade: 18 (máxima) a 32 (menor arquivo). Recomendado: 28–30 para aulas
CRF=30

# FPS da gravação (30 é suficiente para aulas)
FPS=30

# Título da janela do Teams para buscar (pode ser parcial, ex: "Teams" ou "Reunião")
TEAMS_WINDOW_TITLE=Teams
